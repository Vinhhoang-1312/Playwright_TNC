# Example environment variables for Playwright tests against TNC Store
# Copy this to .env and fill values you need. Do NOT commit your .env.

# Base URL for the site under test
BASE_URL=https://www.tncstore.vn/

# Test user credentials (example placeholders)
TEST_USER_EMAIL=your_test_user@example.com
TEST_USER_PASSWORD=changeme

# Timeouts (ms)
DEFAULT_TIMEOUT=30000

# Reporting
ALLURE_RESULTS_DIR=reports/allure-results

# Browser / Playwright options
BROWSER=chromium
HEADLESS=true
