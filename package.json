{
  "name": "playwright-project",
  "version": "1.0.0",
  "description": "Playwright automation project",
  "main": "index.js",
  "scripts": {
    "test": "playwright test tests/web",
    "test:parallel": "playwright test tests/web --workers=4",
    "allure:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "allure:open": "allure open reports/allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open",
    "clean": "node ./scripts/cleanArtifacts.js"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/dotenv": "^6.1.1",
    "@types/xlsx": "^0.0.35",
    "allure-playwright": "^2.0.0",
    "archiver": "^5.3.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "openai": "^6.4.0",
    "xlsx": "^0.18.5"
  }
}